# ============================================================
# Vesno / Workflow Consultancy — environment variables
#
# Copy this to .env.local for development. Set the same values in
# Vercel → Project → Settings → Environment Variables for production
# (per-environment: Production / Preview / Development).
#
# NEVER commit .env.local. NEVER put the model encryption secret here
# (it lives in Supabase Vault, not env). See SECURITY.md.
# ============================================================

# ─── REQUIRED ────────────────────────────────────────────────

# Anthropic — chat agent, deal analysis, recommendations, redesign.
# Customers can BYO their own; this is the platform-default fallback.
ANTHROPIC_API_KEY=sk-ant-api03-...

# Supabase — auth, Postgres, storage, vault.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# JWT secret (Project Settings → API → JWT Settings → "JWT Secret"). When
# set, lib/auth.js verifies user JWTs locally with HS256 instead of doing
# a /auth/v1/user round-trip — saves ~200 ms on the first authenticated
# API request per page-load. Falls through to the network path if unset.
SUPABASE_JWT_SECRET=

# n8n — outbound email + followup webhooks. HMAC-signed.
WEBHOOK_SIGNING_SECRET=                    # 32+ random chars; openssl rand -base64 32
N8N_REPORT_WEBHOOK_URL=https://...         # Diagnostic report email
N8N_FOLLOWUP_WEBHOOK_URL=https://...       # Follow-up campaigns

# GDPR account-deletion cron — owns expunged users' deals so collaborators
# retain access. Must be a real email belonging to a platform admin / shared
# inbox you control. Without it, the cron skips ownership transfer.
PLATFORM_ADMIN_TRANSFER_EMAIL=admin@yourdomain.com

# ─── OPTIONAL (degrades gracefully when missing) ─────────────

# Voyage AI — embeddings for deal-document chunks.
# Without it: hybrid search collapses to keyword-only.
VOYAGE_API_KEY=pa-...

# Inngest — async worker for parse / chunk / embed.
# Without these: document uploads stay at 'pending' indefinitely (the
# stuck-document reaper cron will keep retrying).
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# Set INNGEST_DEV=1 instead of the keys above when running the local
# Inngest dev server (npx inngest-cli@latest dev).
# INNGEST_DEV=1

# Sentry — error monitoring. Without it, errors only go to console.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Upstash Redis — distributed rate limiter.
# Without it: in-memory per-Lambda fallback (works but per-instance only).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel Cron — automatically injected on cron invocations. For local
# manual cron testing, set this so the routes accept your curl calls.
# CRON_SECRET=

# CSRF allowed origins. Comma-separated. Defaults to NEXT_PUBLIC_SITE_URL.
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# OpenAI (FUTURE) — the catalogue lists OpenAI models but no surface
# routes calls there yet. Setting this has no effect today.
# OPENAI_API_KEY=sk-...

# ─── NEVER PUT IN ENV ────────────────────────────────────────
#
# Customer-managed AI API keys live in `customer_api_keys` (encrypted
# via pgcrypto using a key in Supabase Vault). NEVER put a customer's
# Anthropic key here.
#
# The model_key_encryption_secret (the one that decrypts the BYO keys)
# lives in Supabase Vault, set via scripts/set-model-key-encryption-secret.sql.
# NEVER put it here either. A compromised Vercel env should not auto-leak
# customer keys.

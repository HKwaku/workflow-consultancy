# Anthropic Claude API Key (for AI-powered diagnostic recommendations)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# n8n Webhook URLs (separate workflow per email/notification type)
N8N_SAVE_PROGRESS_WEBHOOK_URL=https://your-n8n.app.n8n.cloud/webhook/save-progress
N8N_HANDOVER_WEBHOOK_URL=https://your-n8n.app.n8n.cloud/webhook/handover
N8N_DIAGNOSTIC_COMPLETE_WEBHOOK_URL=https://your-n8n.app.n8n.cloud/webhook/diagnostic-complete
N8N_COST_ANALYSIS_SHARE_WEBHOOK_URL=https://your-n8n.app.n8n.cloud/webhook/cost-analysis-share
N8N_FLOW_DIAGRAM_WEBHOOK_URL=https://your-n8n.app.n8n.cloud/webhook/flow-diagram
N8N_COST_ANALYSIS_WEBHOOK_URL=https://your-n8n.app.n8n.cloud/webhook/cost-analysis-complete
N8N_TEAM_WEBHOOK_URL=https://your-n8n.app.n8n.cloud/webhook/team-notifications
N8N_API_KEY=your-n8n-api-key-optional

# Follow-up API key (required for /api/get-followups - used by n8n cron)
FOLLOWUP_API_KEY=your-secret-followup-key

# Supabase — server-side (used by API routes)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase — client-side (NEXT_PUBLIC_ prefix exposes to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Production: app URL for origin validation (required for checkOrigin CSRF mitigation)
# Set to your deployed URL, e.g. https://your-app.vercel.app
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Optional: Upstash Redis for shared rate limiting (not yet implemented; KV_REST_API_* reserved)
# Optional: LOG_LEVEL=debug|info|warn|error (default: info)
# Optional: PUBLIC_CONFIG_RESTRICTED=true to disable /api/public-config in production

# n8n environment variables (set in n8n Settings → Variables, NOT here)
# The flow-diagram n8n workflow needs these two variables configured inside n8n:
#   SUPABASE_URL       — same value as SUPABASE_URL above
#   SUPABASE_SERVICE_ROLE_KEY — same value as SUPABASE_SERVICE_KEY above
# Without these the workflow falls back to returning a mermaid.ink SVG URL instead of uploading to Storage.

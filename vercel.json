{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "cleanUrls": false,
  "rewrites": [
    { "source": "/(portal|diagnostic|report)(/.*)?", "destination": "/app.html" },
    { "source": "/((?!api/|diagnostic\\.html|landing\\.html|styles/|assets/|videos/|images/).*)", "destination": "/index.html" }
  ],
  "redirects": [
    { "source": "/dashboard", "destination": "/portal", "statusCode": 301 }
  ],
  "functions": {
    "api/*.js": { "maxDuration": 60 }
  }
}
